{
  "name": "mincemeat-docs",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vitepress dev .",
    "build": "vitepress build .",
    "preview": "vitepress preview .",
    "typecheck": "tsc --noEmit -p .vitepress/tsconfig.json",
    "lint:links": "node scripts/check-links.mjs",
    "lint:frontmatter": "node scripts/check-frontmatter.mjs",
    "lint:markdown": "markdownlint-cli2 \"**/*.md\" \"#node_modules\" \"#.vitepress/dist\" \"#.vitepress/cache\"",
    "scan:secrets": "node scripts/scan-secrets.mjs"
  },
  "dependencies": {
    "vitepress": "1.6.4",
    "vue": "^3.5.32"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "markdownlint-cli2": "^0.13.0",
    "typescript": "^5.6.0",
    "vitepress-plugin-llms": "^1.12.2"
  }
}
